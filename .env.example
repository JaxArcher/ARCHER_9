# ARCHER Environment Configuration
# Copy this file to .env and fill in your API keys.

# --- LLM ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Voice (Cloud Mode) ---
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Mode ---
# Options: cloud, local
ARCHER_DEFAULT_MODE=cloud

# --- Audio ---
# Set to your preferred microphone device index (leave blank for default)
ARCHER_MIC_DEVICE_INDEX=
# Set to your preferred speaker device index (leave blank for default)
ARCHER_SPEAKER_DEVICE_INDEX=

# --- Paths ---
ARCHER_DATA_DIR=./data
ARCHER_LOG_DIR=./logs
